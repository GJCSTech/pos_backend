NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# PostgreSQL
DATABASE_URL=postgresql://vjgarden:vjgarden_secret@localhost:5432/vj_garden_pos?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Seed (development only — never use defaults in production)
SEED_ADMIN_EMAIL=admin@vjgarden.local
SEED_ADMIN_PASSWORD=ChangeMeAdmin!2026
SEED_COMPANY_NAME=VJ Garden Boutique
SEED_BRANCH_NAME=Main Store
SEED_BRANCH_CODE=MAIN
