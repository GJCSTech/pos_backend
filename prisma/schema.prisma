// VJ Garden POS Backend — PostgreSQL schema (Release 0.1.0)
// Foundation for multi-branch offline sync (SQLite devices ↔ PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  UNKNOWN
}

enum DeviceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

/// Tenant root. companyId mirrors id for common-column consistency.
model Company {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String?   @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name      String  @db.VarChar(200)
  code      String  @unique @db.VarChar(50)
  legalName String? @map("legal_name") @db.VarChar(255)
  gstin     String? @db.VarChar(20)
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(30)
  isActive  Boolean @default(true) @map("is_active")

  branches    Branch[]
  users       User[]
  roles       Role[]
  permissions Permission[]
  devices     Device[]
  refreshTokens RefreshToken[]

  @@index([deletedAt])
  @@map("companies")
}

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name     String  @db.VarChar(200)
  code     String  @db.VarChar(50)
  address  String? @db.VarChar(500)
  city     String? @db.VarChar(100)
  state    String? @db.VarChar(100)
  pincode  String? @db.VarChar(20)
  phone    String? @db.VarChar(30)
  email    String? @db.VarChar(255)
  timezone String  @default("Asia/Kolkata") @db.VarChar(64)
  isActive Boolean @default(true) @map("is_active")
  isMain   Boolean @default(false) @map("is_main")

  company Company @relation(fields: [companyId], references: [id])
  users   User[]
  devices Device[]
  roles   Role[]
  refreshTokens RefreshToken[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
  @@map("branches")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  email          String     @db.VarChar(255)
  username       String     @db.VarChar(100)
  passwordHash   String     @map("password_hash") @db.VarChar(255)
  displayName    String     @map("display_name") @db.VarChar(200)
  phone          String?    @db.VarChar(30)
  status         UserStatus @default(ACTIVE)
  failedLogins   Int        @default(0) @map("failed_logins")
  lockedUntil    DateTime?  @map("locked_until") @db.Timestamptz(3)
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz(3)
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(3)

  company       Company        @relation(fields: [companyId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  devices       Device[]

  @@unique([companyId, email])
  @@unique([companyId, username])
  @@index([companyId, branchId, deletedAt])
  @@index([status])
  @@map("users")
}

model Role {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  code        String  @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  isSystem    Boolean @default(false) @map("is_system")

  company         Company          @relation(fields: [companyId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
  @@map("roles")
}

model Permission {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String?   @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  code        String  @unique @db.VarChar(100)
  name        String  @db.VarChar(150)
  module      String  @db.VarChar(50)
  description String? @db.VarChar(500)

  company         Company?         @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]

  @@index([module])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([companyId])
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([companyId])
  @@map("user_roles")
}

model Device {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  deviceUuid String         @map("device_uuid") @db.VarChar(64)
  platform   DevicePlatform @default(ANDROID)
  deviceName String         @map("device_name") @db.VarChar(200)
  appVersion String         @map("app_version") @db.VarChar(50)
  status     DeviceStatus   @default(PENDING)
  lastSyncAt DateTime?      @map("last_sync_at") @db.Timestamptz(3)
  registeredById String?    @map("registered_by_id") @db.Uuid
  metadata   Json?

  company      Company @relation(fields: [companyId], references: [id])
  branch       Branch  @relation(fields: [branchId], references: [id])
  registeredBy User?   @relation(fields: [registeredById], references: [id])

  @@unique([companyId, deviceUuid])
  @@index([companyId, branchId, status])
  @@index([lastSyncAt])
  @@map("devices")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  replacedByTokenId String? @map("replaced_by_token_id") @db.Uuid
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.VarChar(64)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([tokenHash])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
