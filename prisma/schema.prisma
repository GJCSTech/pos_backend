  company  Company   @relation(fields: [companyId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  sale     Sale      @relation(fields: [saleId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([companyId, holdNumber])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@map("hold_bills")
}

model Payment {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  targetType  PaymentTarget @map("target_type")
  saleId      String?       @map("sale_id") @db.Uuid
  purchaseId  String?       @map("purchase_id") @db.Uuid
  method      PaymentMethod
  status      PaymentStatus @default(COMPLETED)
  amount      Decimal       @db.Decimal(18, 2)
  referenceNo String?       @map("reference_no") @db.VarChar(100)
  paidAt      DateTime      @default(now()) @map("paid_at") @db.Timestamptz(3)
  notes       String?       @db.VarChar(500)

  company  Company   @relation(fields: [companyId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([companyId, branchId, deletedAt])
  @@index([companyId, saleId])
  @@index([companyId, purchaseId])
  @@index([companyId, method, paidAt])
  @@map("payments")
}

model BusinessSetting {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  key         String  @db.VarChar(100)
  value       Json
  description String? @db.VarChar(500)
  isActive    Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([companyId, branchId, key])
  @@index([companyId, branchId, deletedAt])
  @@map("business_settings")
}

model ReceiptSetting {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  headerText       String? @map("header_text") @db.VarChar(500)
  footerText       String? @map("footer_text") @db.VarChar(500)
  showLogo         Boolean @default(true) @map("show_logo")
  logoUrl          String? @map("logo_url") @db.VarChar(500)
  showGstin        Boolean @default(true) @map("show_gstin")
  showAddress      Boolean @default(true) @map("show_address")
  showCustomerInfo Boolean @default(true) @map("show_customer_info")
  paperWidthMm     Int     @default(80) @map("paper_width_mm")
  copies           Int     @default(1)
  extraSettings    Json?   @map("extra_settings")
  isActive         Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([companyId, branchId])
  @@index([companyId, deletedAt])
  @@map("receipt_settings")
}
