// VJ Garden POS Backend — PostgreSQL schema
// Release 0.1.0: Foundation | 0.2.0: Enterprise Business Core | 0.2.1: Sync indexes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  UNKNOWN
}

enum DeviceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum CustomerType {
  WALK_IN
  RETAIL
  WHOLESALE
}

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
}

enum StockMovementType {
  OPENING
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALE_RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum PurchaseReturnStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  HELD
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  CREDIT
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentTarget {
  SALE
  PURCHASE
}

/// Tenant root. companyId mirrors id for common-column consistency.
model Company {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String?   @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name      String  @db.VarChar(200)
  code      String  @unique @db.VarChar(50)
  legalName String? @map("legal_name") @db.VarChar(255)
  gstin     String? @db.VarChar(20)
  email     String? @db.VarChar(255)
  phone     String? @db.VarChar(30)
  isActive  Boolean @default(true) @map("is_active")

  branches           Branch[]
  users              User[]
  roles              Role[]
  permissions        Permission[]
  devices            Device[]
  refreshTokens      RefreshToken[]
  productCategories  ProductCategory[]
  productAttributes  ProductAttribute[]
  products           Product[]
  productVariants    ProductVariant[]
  units              Unit[]
  taxMasters         TaxMaster[]
  suppliers          Supplier[]
  customers          Customer[]
  customerGroups     CustomerGroup[]
  inventories        Inventory[]
  stockMovements     StockMovement[]
  openingStocks      OpeningStock[]
  purchases          Purchase[]
  purchaseItems      PurchaseItem[]
  purchaseReturns    PurchaseReturn[]
  sales              Sale[]
  saleItems          SaleItem[]
  holdBills          HoldBill[]
  payments           Payment[]
  businessSettings   BusinessSetting[]
  receiptSettings    ReceiptSetting[]
  productUnits       ProductUnit[]

  @@index([deletedAt])
  @@map("companies")
}

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name     String  @db.VarChar(200)
  code     String  @db.VarChar(50)
  address  String? @db.VarChar(500)
  city     String? @db.VarChar(100)
  state    String? @db.VarChar(100)
  pincode  String? @db.VarChar(20)
  phone    String? @db.VarChar(30)
  email    String? @db.VarChar(255)
  timezone String  @default("Asia/Kolkata") @db.VarChar(64)
  isActive Boolean @default(true) @map("is_active")
  isMain   Boolean @default(false) @map("is_main")

  company            Company             @relation(fields: [companyId], references: [id])
  users              User[]
  devices            Device[]
  roles              Role[]
  refreshTokens      RefreshToken[]
  productCategories  ProductCategory[]
  productAttributes  ProductAttribute[]
  products           Product[]
  productVariants    ProductVariant[]
  units              Unit[]
  taxMasters         TaxMaster[]
  suppliers          Supplier[]
  customers          Customer[]
  customerGroups     CustomerGroup[]
  inventories        Inventory[]
  stockMovements     StockMovement[]
  openingStocks      OpeningStock[]
  purchases          Purchase[]
  purchaseItems      PurchaseItem[]
  purchaseReturns    PurchaseReturn[]
  sales              Sale[]
  saleItems          SaleItem[]
  holdBills          HoldBill[]
  payments           Payment[]
  businessSettings   BusinessSetting[]
  receiptSettings    ReceiptSetting[]
  productUnits       ProductUnit[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
  @@map("branches")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  email             String     @db.VarChar(255)
  username          String     @db.VarChar(100)
  passwordHash      String     @map("password_hash") @db.VarChar(255)
  displayName       String     @map("display_name") @db.VarChar(200)
  phone             String?    @db.VarChar(30)
  status            UserStatus @default(ACTIVE)
  failedLogins      Int        @default(0) @map("failed_logins")
  lockedUntil       DateTime?  @map("locked_until") @db.Timestamptz(3)
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz(3)
  passwordChangedAt DateTime?  @map("password_changed_at") @db.Timestamptz(3)

  company       Company        @relation(fields: [companyId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  devices       Device[]

  @@unique([companyId, email])
  @@unique([companyId, username])
  @@index([companyId, branchId, deletedAt])
  @@index([status])
  @@map("users")
}

model Role {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  code        String  @db.VarChar(50)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  isSystem    Boolean @default(false) @map("is_system")

  company         Company          @relation(fields: [companyId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, code])
  @@index([companyId, deletedAt])
  @@map("roles")
}

model Permission {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String?   @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  code        String  @unique @db.VarChar(100)
  name        String  @db.VarChar(150)
  module      String  @db.VarChar(50)
  description String? @db.VarChar(500)

  company         Company?         @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]

  @@index([module])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([companyId])
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([companyId])
  @@map("user_roles")
}

model Device {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  deviceUuid     String         @map("device_uuid") @db.VarChar(64)
  platform       DevicePlatform @default(ANDROID)
  deviceName     String         @map("device_name") @db.VarChar(200)
  appVersion     String         @map("app_version") @db.VarChar(50)
  status         DeviceStatus   @default(PENDING)
  lastSyncAt     DateTime?      @map("last_sync_at") @db.Timestamptz(3)
  registeredById String?        @map("registered_by_id") @db.Uuid
  metadata       Json?

  company      Company @relation(fields: [companyId], references: [id])
  branch       Branch  @relation(fields: [branchId], references: [id])
  registeredBy User?   @relation(fields: [registeredById], references: [id])

  @@unique([companyId, deviceUuid])
  @@index([companyId, branchId, status])
  @@index([lastSyncAt])
  @@map("devices")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @map("token_hash") @db.VarChar(128)
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(3)
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  userAgent         String?   @map("user_agent") @db.VarChar(500)
  ipAddress         String?   @map("ip_address") @db.VarChar(64)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([tokenHash])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name        String  @db.VarChar(200)
  code        String  @db.VarChar(50)
  description String? @db.VarChar(500)
  parentId    String? @map("parent_id") @db.Uuid
  sortOrder   Int     @default(0) @map("sort_order")
  imageUrl    String? @map("image_url") @db.VarChar(500)
  isActive    Boolean @default(true) @map("is_active")

  company  Company           @relation(fields: [companyId], references: [id])
  branch   Branch            @relation(fields: [branchId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, parentId])
  @@index([companyId, isActive])
  @@map("product_categories")
}

model ProductAttribute {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name     String            @db.VarChar(150)
  code     String            @db.VarChar(50)
  dataType AttributeDataType @default(TEXT) @map("data_type")
  options  Json?
  isActive Boolean           @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@map("product_attributes")
}

model Unit {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name             String  @db.VarChar(100)
  code             String  @db.VarChar(30)
  symbol           String  @db.VarChar(20)
  isBase           Boolean @default(false) @map("is_base")
  conversionFactor Decimal @default(1) @map("conversion_factor") @db.Decimal(18, 6)
  isActive         Boolean @default(true) @map("is_active")

  company       Company        @relation(fields: [companyId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  products      Product[]      @relation("ProductBaseUnit")
  productUnits  ProductUnit[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@map("units")
}

model TaxMaster {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name     String  @db.VarChar(150)
  code     String  @db.VarChar(50)
  hsnSac   String? @map("hsn_sac") @db.VarChar(20)
  rate     Decimal @db.Decimal(8, 4)
  cgstRate Decimal @default(0) @map("cgst_rate") @db.Decimal(8, 4)
  sgstRate Decimal @default(0) @map("sgst_rate") @db.Decimal(8, 4)
  igstRate Decimal @default(0) @map("igst_rate") @db.Decimal(8, 4)
  isActive Boolean @default(true) @map("is_active")

  company  Company   @relation(fields: [companyId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  products Product[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@map("tax_masters")
}

model Supplier {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name               String  @db.VarChar(200)
  code               String  @db.VarChar(50)
  contactPerson      String? @map("contact_person") @db.VarChar(150)
  email              String? @db.VarChar(255)
  phone              String? @db.VarChar(30)
  gstin              String? @db.VarChar(20)
  pan                String? @db.VarChar(20)
  address            String? @db.VarChar(500)
  city               String? @db.VarChar(100)
  state              String? @db.VarChar(100)
  pincode            String? @db.VarChar(20)
  paymentTerms       String? @map("payment_terms") @db.VarChar(200)
  outstandingBalance Decimal @default(0) @map("outstanding_balance") @db.Decimal(18, 2)
  isActive           Boolean @default(true) @map("is_active")
  notes              String? @db.VarChar(1000)

  company   Company    @relation(fields: [companyId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  products  Product[]
  purchases Purchase[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@index([companyId, gstin])
  @@index([companyId, updatedAt])
  @@map("suppliers")
}

model CustomerGroup {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name            String  @db.VarChar(150)
  code            String  @db.VarChar(50)
  description     String? @db.VarChar(500)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(8, 4)
  priceListType   String  @default("RETAIL") @map("price_list_type") @db.VarChar(30)
  isActive        Boolean @default(true) @map("is_active")

  company   Company    @relation(fields: [companyId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  customers Customer[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, isActive])
  @@map("customer_groups")
}

model Customer {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name            String       @db.VarChar(200)
  code            String       @db.VarChar(50)
  customerType    CustomerType @default(RETAIL) @map("customer_type")
  customerGroupId String?      @map("customer_group_id") @db.Uuid
  email           String?      @db.VarChar(255)
  phone           String?      @db.VarChar(30)
  gstin           String?      @db.VarChar(20)
  address         String?      @db.VarChar(500)
  city            String?      @db.VarChar(100)
  state           String?      @db.VarChar(100)
  pincode         String?      @db.VarChar(20)
  creditLimit     Decimal      @default(0) @map("credit_limit") @db.Decimal(18, 2)
  outstandingBalance Decimal   @default(0) @map("outstanding_balance") @db.Decimal(18, 2)
  loyaltyPoints   Decimal      @default(0) @map("loyalty_points") @db.Decimal(18, 2)
  loyaltyReady    Boolean      @default(true) @map("loyalty_ready")
  isWalkIn        Boolean      @default(false) @map("is_walk_in")
  isActive        Boolean      @default(true) @map("is_active")
  notes           String?      @db.VarChar(1000)

  company       Company        @relation(fields: [companyId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  customerGroup CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  sales         Sale[]
  holdBills     HoldBill[]

  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, customerType])
  @@index([companyId, phone])
  @@index([companyId, isActive])
  @@index([companyId, updatedAt])
  @@map("customers")
}

model Product {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  name                 String  @db.VarChar(255)
  code                 String  @db.VarChar(50)
  sku                  String  @db.VarChar(100)
  barcode              String? @db.VarChar(100)
  qrCode               String? @map("qr_code") @db.VarChar(255)
  description          String? @db.VarChar(2000)
  categoryId           String? @map("category_id") @db.Uuid
  taxMasterId          String? @map("tax_master_id") @db.Uuid
  supplierId           String? @map("supplier_id") @db.Uuid
  baseUnitId           String? @map("base_unit_id") @db.Uuid
  brand                String? @db.VarChar(150)
  manufacturer         String? @db.VarChar(150)
  purchasePrice        Decimal @default(0) @map("purchase_price") @db.Decimal(18, 4)
  mrp                  Decimal @default(0) @db.Decimal(18, 4)
  sellingPrice         Decimal @default(0) @map("selling_price") @db.Decimal(18, 4)
  wholesalePrice       Decimal @default(0) @map("wholesale_price") @db.Decimal(18, 4)
  imageUrl             String? @map("image_url") @db.VarChar(500)
  thumbnailUrl         String? @map("thumbnail_url") @db.VarChar(500)
  minimumStock         Decimal @default(0) @map("minimum_stock") @db.Decimal(18, 4)
  maximumStock         Decimal @default(0) @map("maximum_stock") @db.Decimal(18, 4)
  reorderLevel         Decimal @default(0) @map("reorder_level") @db.Decimal(18, 4)
  expiryEnabled        Boolean @default(false) @map("expiry_enabled")
  batchEnabled         Boolean @default(false) @map("batch_enabled")
  serialNumberEnabled  Boolean @default(false) @map("serial_number_enabled")
  trackInventory       Boolean @default(true) @map("track_inventory")
  isActive             Boolean @default(true) @map("is_active")
  searchKeywords       String? @map("search_keywords") @db.VarChar(1000)
  attributes           Json?

  company         Company          @relation(fields: [companyId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id])
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  taxMaster       TaxMaster?       @relation(fields: [taxMasterId], references: [id])
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  baseUnit        Unit?            @relation("ProductBaseUnit", fields: [baseUnitId], references: [id])
  variants        ProductVariant[]
  productUnits    ProductUnit[]
  inventories     Inventory[]
  stockMovements  StockMovement[]
  openingStocks   OpeningStock[]
  purchaseItems   PurchaseItem[]
  saleItems       SaleItem[]

  @@unique([companyId, sku])
  @@unique([companyId, code])
  @@index([companyId, branchId, deletedAt])
  @@index([companyId, barcode])
  @@index([companyId, categoryId])
  @@index([companyId, isActive])
  @@index([companyId, brand])
  @@index([companyId, updatedAt])
  @@map("products")
}

model ProductVariant {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  productId      String  @map("product_id") @db.Uuid
  name           String  @db.VarChar(255)
  sku            String  @db.VarChar(100)
  barcode        String? @db.VarChar(100)
  qrCode         String? @map("qr_code") @db.VarChar(255)
  purchasePrice  Decimal @default(0) @map("purchase_price") @db.Decimal(18, 4)
  mrp            Decimal @default(0) @db.Decimal(18, 4)
  sellingPrice   Decimal @default(0) @map("selling_price") @db.Decimal(18, 4)
  wholesalePrice Decimal @default(0) @map("wholesale_price") @db.Decimal(18, 4)
  imageUrl       String? @map("image_url") @db.VarChar(500)
  thumbnailUrl   String? @map("thumbnail_url") @db.VarChar(500)
  attributeValues Json?  @map("attribute_values")
  isActive       Boolean @default(true) @map("is_active")

  company        Company         @relation(fields: [companyId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  inventories    Inventory[]
  stockMovements StockMovement[]
  openingStocks  OpeningStock[]
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]

  @@unique([companyId, sku])
  @@index([companyId, productId, deletedAt])
  @@index([companyId, barcode])
  @@index([companyId, isActive])
  @@map("product_variants")
}

model ProductUnit {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(3)
  version   Int       @default(1)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  productId        String  @map("product_id") @db.Uuid
  unitId           String  @map("unit_id") @db.Uuid
  conversionFactor Decimal @default(1) @map("conversion_factor") @db.Decimal(18, 6)
  sellingPrice     Decimal? @map("selling_price") @db.Decimal(18, 4)
  barcode          String? @db.VarChar(100)
  isDefault        Boolean @default(false) @map("is_default")
  isActive         Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@unique([companyId, productId, unitId])
  @@index([companyId, productId, deletedAt])
  @@map("product_units")
}

model Inventory {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
